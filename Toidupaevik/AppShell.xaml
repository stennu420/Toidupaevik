<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Toidupaevik.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Toidupaevik.Views"
    Title="Toidupaevik">

    <FlyoutItem Title="Avaleht">
        <ShellContent
            Title="Avaleht"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Seaded">
        <ShellContent
            Title="Seaded"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </FlyoutItem>

</Shell>
